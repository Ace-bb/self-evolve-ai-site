---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const tools = await getCollection('tools', ({ data }) => !data.draft);
  const categories = [...new Set(tools.flatMap(t => t.data.category))];
  return categories.map(cat => {
    const filteredTools = tools.filter(t => t.data.category.includes(cat));
    return {
      params: { slug: cat.toLowerCase() },
      props: { category: cat, tools: filteredTools },
    };
  });
}

const { category, tools } = Astro.props;
const sortedTools = tools.sort((a, b) => b.data.rating - a.data.rating);
const allCategories = [...new Set((await getCollection('tools', ({ data }) => !data.draft)).flatMap(t => t.data.category))];
---

<Layout title={`${category} - AI 工具箱`} description={`${category} 分类下的所有工具`}>
  <section class="section-padding">
    <div class="container">
      <nav class="text-sm text-[var(--text-muted)] mb-6">
        <a href="/" class="hover:text-[var(--text-primary)]">首页</a>
        <span class="mx-2">/</span>
        <a href="/toolbox" class="hover:text-[var(--text-primary)]">AI 工具箱</a>
        <span class="mx-2">/</span>
        <span>{category}</span>
      </nav>

      <div class="mb-8">
        <h1 class="text-3xl md:text-4xl font-bold mb-2">📂 {category}</h1>
        <p class="text-[var(--text-secondary)]">共 {sortedTools.length} 个工具</p>
      </div>

      <div class="mb-8 flex flex-wrap gap-2">
        <a href="/toolbox" class="badge hover:bg-[var(--color-primary)]/10 hover:text-[var(--color-primary)] transition-colors">全部</a>
        {allCategories.map((cat) => (
          <a
            href={`/toolbox/category/${cat.toLowerCase()}`}
            class={`badge transition-colors ${cat === category ? 'badge-primary' : 'hover:bg-[var(--color-primary)]/10 hover:text-[var(--color-primary)]'}`}
          >
            {cat}
          </a>
        ))}
      </div>

      <div class="grid-responsive">
        {sortedTools.map((tool) => (
          <a href={`/toolbox/${tool.id}`} class="card group">
            <div class="flex items-start gap-3 mb-4">
              <div class="w-12 h-12 rounded-xl bg-[var(--bg-tertiary)] flex items-center justify-center text-xl flex-shrink-0">
                {tool.data.logo ? <img src={tool.data.logo} alt={tool.data.name} class="w-8 h-8" /> : '🛠️'}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <h3 class="font-semibold group-hover:text-[var(--color-primary)] transition-colors truncate">{tool.data.name}</h3>
                  {tool.data.featured && <span class="text-xs">🔥</span>}
                </div>
                <div class="flex items-center gap-1 mt-1">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg class={`w-3.5 h-3.5 ${i < Math.round(tool.data.rating) ? 'text-amber-400' : 'text-[var(--text-muted)]'}`} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                  ))}
                  <span class="text-xs text-[var(--text-muted)] ml-1">{tool.data.rating.toFixed(1)}</span>
                </div>
              </div>
            </div>
            <p class="text-sm text-[var(--text-secondary)] mb-4 line-clamp-2">{tool.data.description}</p>
            <span class={`inline-block text-xs px-2 py-0.5 rounded-full ${
              tool.data.pricing === 'free' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' :
              tool.data.pricing === 'freemium' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' :
              'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400'
            }`}>
              {tool.data.pricing === 'free' ? '免费' : tool.data.pricing === 'freemium' ? '免费+付费' : '付费'}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
