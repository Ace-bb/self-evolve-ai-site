---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTools = await getCollection('tools', ({ data }) => !data.draft);
const tools = allTools.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return b.data.rating - a.data.rating;
});

const categories = [...new Set(allTools.flatMap(t => t.data.category))];
---

<Layout title="AI 工具箱" description="实用 AI 工具聚合、评测、使用指南">
  <section class="section-padding">
    <div class="container">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">🧰 AI 工具箱</h1>
      <p class="text-[var(--text-secondary)] mb-8">精选实用 AI 工具，包含详细评测和使用指南</p>

      <!-- Category Filter -->
      <div class="mb-8 flex flex-wrap gap-2">
        <a href="/toolbox" class="badge badge-primary">全部</a>
        {categories.map((cat) => (
          <a href={`/toolbox/category/${cat.toLowerCase()}`} class="badge">{cat}</a>
        ))}
      </div>

      <!-- Tools Grid -->
      <div class="grid-responsive">
        {tools.map((tool) => (
          <a href={`/toolbox/${tool.id}`} class="card group">
            <div class="flex items-start gap-3 mb-4">
              <div class="w-12 h-12 rounded-xl bg-[var(--bg-tertiary)] flex items-center justify-center text-xl flex-shrink-0">
                {tool.data.logo ? <img src={tool.data.logo} alt={tool.data.name} class="w-8 h-8" /> : '🛠️'}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <h3 class="font-semibold group-hover:text-[var(--color-primary)] transition-colors truncate">{tool.data.name}</h3>
                  {tool.data.featured && <span class="text-xs">🔥</span>}
                </div>
                <div class="flex items-center gap-1 mt-1">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg class={`w-3.5 h-3.5 ${i < Math.round(tool.data.rating) ? 'text-amber-400' : 'text-[var(--text-muted)]'}`} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                  ))}
                  <span class="text-xs text-[var(--text-muted)] ml-1">{tool.data.rating.toFixed(1)}</span>
                </div>
              </div>
            </div>
            <p class="text-sm text-[var(--text-secondary)] mb-4 line-clamp-2">{tool.data.description}</p>
            <div class="flex flex-wrap gap-1 mb-3">
              {tool.data.category.slice(0, 3).map(cat => (
                <span class="badge">{cat}</span>
              ))}
            </div>
            <span class={`inline-block text-xs px-2 py-0.5 rounded-full ${
              tool.data.pricing === 'free' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' :
              tool.data.pricing === 'freemium' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' :
              'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400'
            }`}>
              {tool.data.pricing === 'free' ? '免费' : tool.data.pricing === 'freemium' ? '免费+付费' : '付费'}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
