const allItems = [...newsItems];

// Prepare items for MasterDetailLayout
const mdItems = allItems.map((item) => ({
  id: item.id,
  title: item.title,
  category: item.category,
  tags: item.tags,
  date: item.date,
  summary: item.summary,
  coverImage: undefined,
}));
---

<Layout title="AI 资讯" description="AI 领域最新热点资讯、行业动态">
  <section class="section-padding">
    <div class="w-[90%] mx-auto">

      <!-- Page Header -->
      <div class="mb-6">
        <h1 class="text-3xl md:text-4xl font-bold mb-2">📰 AI 资讯</h1>
        <p class="text-[var(--text-secondary)]">AI 领域最新热点资讯，聚合全球行业动态</p>
      </div>

      <!-- Category Filter -->
      <div class="flex flex-wrap gap-2 mb-6" id="news-category-filter">
        {categories.map((cat, i) => (
          <button
            class={`category-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all ${
              i === 0
                ? 'bg-[var(--color-primary)] text-white'
                : 'bg-[var(--bg-secondary)] text-[var(--text-secondary)] hover:bg-[var(--color-primary)]/10 hover:text-[var(--color-primary)] border border-[var(--border-color)]'
            }`}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <MasterDetailLayout
        items={mdItems}
      >
        <!-- Pre-rendered article content -->
        {allItems.map((item) => (
          <div class="md-article prose max-w-none" data-article-id={item.id}>
            <div class="flex gap-2 mb-4 flex-wrap">
              <span class="badge badge-primary">{item.category}</span>
              {item.hot && <span class="badge" style="color: #ef4444;">🔥 HOT</span>}
              {item.tags.map((tag) => <span class="badge">{tag}</span>)}
            </div>
            <h1 class="text-2xl md:text-3xl font-bold mb-3">{item.title}</h1>
            <div class="flex items-center gap-4 text-sm text-[var(--text-muted)] mb-8">
              <span>{item.source}</span>
              <span>·</span>
              <time datetime={item.date}>{item.date}</time>
            </div>
            <div set:html={item.body} />
          </div>
        ))}
      </MasterDetailLayout>

    </div>
  </section>
</Layout>

<style>
  .category-btn {
    cursor: pointer;
  }
</style>

<script>
  // Category filter
  document.querySelectorAll('#news-category-filter .category-btn').forEach((btn) => {
    btn.addEventListener('click', function() {
      const category = this.getAttribute('data-category');

      // Update button styles
      document.querySelectorAll('#news-category-filter .category-btn').forEach((b) => {
        const bEl = b as HTMLElement;
        bEl.classList.remove('bg-[var(--color-primary)]', 'text-white');
        bEl.classList.add('bg-[var(--bg-secondary)]', 'text-[var(--text-secondary)]');
      });
      (this as HTMLElement).classList.add('bg-[var(--color-primary)]', 'text-white');
      (this as HTMLElement).classList.remove('bg-[var(--bg-secondary)]', 'text-[var(--text-secondary)]');
    });
  });
</script>
