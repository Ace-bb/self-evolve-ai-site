---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allBlogPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allBlogPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const allTools = await getCollection('tools', ({ data }) => !data.draft && data.featured);
const featuredTools = allTools.slice(0, 3);

const modules = [
  { icon: '📝', title: '个人博客', desc: '技术文章、项目分享、思考总结', href: '/blog', color: 'from-indigo-500 to-purple-600' },
  { icon: '🤖', title: 'AI 咨询', desc: 'AI 领域咨询、方案定制、技术顾问', href: '/consulting', color: 'from-cyan-500 to-blue-600' },
  { icon: '📚', title: '学习笔记', desc: '技术笔记、知识积累、学习路径', href: '/notes', color: 'from-emerald-500 to-teal-600' },
  { icon: '🧰', title: 'AI 工具箱', desc: '实用工具聚合、评测、使用指南', href: '/toolbox', color: 'from-amber-500 to-orange-600' },
];
---

<Layout title="首页" description="个人 AI 综合网站 — 博客 · AI 咨询 · 学习笔记 · AI 工具箱">
  <slot name="head" />

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 md:py-28">
    <div class="container text-center">
      <div class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--bg-secondary)] border border-[var(--border-color)] text-sm text-[var(--text-secondary)]">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        <span>AI Agent 开发者</span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
        探索 AI 的无限可能
        <br />
        <span class="bg-gradient-to-r from-indigo-500 via-purple-500 to-cyan-500 bg-clip-text text-transparent">
          构建智能的未来
        </span>
      </h1>
      <p class="text-lg md:text-xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-10">
        AI Agent 开发者的个人空间。分享技术博客，提供 AI 咨询服务，
        记录学习笔记，聚合实用工具。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/blog" class="btn btn-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
          浏览博客
        </a>
        <a href="/consulting" class="btn btn-outline">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
          AI 咨询
        </a>
      </div>
    </div>
  </section>

  <!-- Modules Section -->
  <section class="section-padding bg-[var(--bg-secondary)]">
    <div class="container">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-12">探索更多</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {modules.map((mod) => (
          <a href={mod.href} class="card group">
            <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${mod.color} flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform`}>
              {mod.icon}
            </div>
            <h3 class="text-lg font-semibold mb-2">{mod.title}</h3>
            <p class="text-sm text-[var(--text-secondary)]">{mod.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Posts Section -->
  {recentPosts.length > 0 && (
    <section class="section-padding">
      <div class="container">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl md:text-3xl font-bold">最新文章</h2>
          <a href="/blog" class="text-sm text-[var(--color-primary)] hover:underline">查看全部 →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {recentPosts.map((post) => (
            <article class="card group">
              {post.data.coverImage && (
                <div class="mb-4 rounded-lg overflow-hidden">
                  <img src={post.data.coverImage} alt={post.data.title} class="w-full h-40 object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                </div>
              )}
              <div class="flex gap-2 mb-3 flex-wrap">
                <span class="badge badge-primary">{post.data.category}</span>
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="badge">{tag}</span>
                ))}
              </div>
              <h3 class="text-lg font-semibold mb-2 group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="text-sm text-[var(--text-secondary)] mb-4 line-clamp-2">{post.data.summary}</p>
              <div class="flex items-center justify-between text-xs text-[var(--text-muted)]">
                <time datetime={String(post.data.date)}>
                  {new Date(post.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span>约 {Math.ceil(post.body?.length || 100 / 500)} 分钟阅读</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Featured Tools Section -->
  {featuredTools.length > 0 && (
    <section class="section-padding bg-[var(--bg-secondary)]">
      <div class="container">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl md:text-3xl font-bold">🔥 精选工具推荐</h2>
          <a href="/toolbox" class="text-sm text-[var(--color-primary)] hover:underline">查看全部 →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {featuredTools.map((tool) => (
            <a href={`/toolbox/${tool.id}`} class="card group">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-lg bg-[var(--bg-tertiary)] flex items-center justify-center text-lg">
                  {tool.data.logo ? <img src={tool.data.logo} alt={tool.data.name} class="w-6 h-6" /> : '🛠️'}
                </div>
                <h3 class="font-semibold group-hover:text-[var(--color-primary)] transition-colors">{tool.data.name}</h3>
              </div>
              <p class="text-sm text-[var(--text-secondary)] mb-3 line-clamp-2">{tool.data.description}</p>
              <div class="flex items-center justify-between">
                <div class="flex gap-1">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg class={`w-4 h-4 ${i < Math.round(tool.data.rating) ? 'text-amber-400' : 'text-[var(--text-muted)]'}`} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                  ))}
                </div>
                <span class={`text-xs px-2 py-0.5 rounded-full ${
                  tool.data.pricing === 'free' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' :
                  tool.data.pricing === 'freemium' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' :
                  'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400'
                }`}>
                  {tool.data.pricing === 'free' ? '免费' : tool.data.pricing === 'freemium' ? '免费+付费' : '付费'}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="section-padding">
    <div class="container text-center">
      <div class="max-w-2xl mx-auto card bg-gradient-to-br from-indigo-50 to-purple-50 dark:from-indigo-950/30 dark:to-purple-950/30 border-indigo-200 dark:border-indigo-800">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">需要 AI 领域咨询？</h2>
        <p class="text-[var(--text-secondary)] mb-6">
          无论是 AI Agent 开发、模型微调还是技术架构设计，我都可以提供专业的咨询服务。
        </p>
        <a href="/consulting" class="btn btn-primary">
          了解更多
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
