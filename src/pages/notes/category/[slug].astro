---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  const categories = [...new Set(notes.map(n => n.data.category))];
  return categories.map(cat => {
    const filteredNotes = notes.filter(n => n.data.category === cat);
    return {
      params: { slug: cat.toLowerCase() },
      props: { category: cat, notes: filteredNotes },
    };
  });
}

const { category, notes } = Astro.props;
const sortedNotes = notes.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const allCategories = [...new Set((await getCollection('notes', ({ data }) => !data.draft)).map(n => n.data.category))];
---

<Layout title={`${category} - 学习笔记`} description={`${category} 分类下的所有笔记`}>
  <section class="section-padding">
    <div class="container">
      <nav class="text-sm text-[var(--text-muted)] mb-6">
        <a href="/" class="hover:text-[var(--text-primary)]">首页</a>
        <span class="mx-2">/</span>
        <a href="/notes" class="hover:text-[var(--text-primary)]">学习笔记</a>
        <span class="mx-2">/</span>
        <span>{category}</span>
      </nav>

      <div class="mb-8">
        <h1 class="text-3xl md:text-4xl font-bold mb-2">📂 {category}</h1>
        <p class="text-[var(--text-secondary)]">共 {sortedNotes.length} 篇笔记</p>
      </div>

      <div class="mb-8 flex flex-wrap gap-2">
        <a href="/notes" class="badge hover:bg-[var(--color-primary)]/10 hover:text-[var(--color-primary)] transition-colors">全部</a>
        {allCategories.map((cat) => (
          <a
            href={`/notes/category/${cat.toLowerCase()}`}
            class={`badge transition-colors ${cat === category ? 'badge-primary' : 'hover:bg-[var(--color-primary)]/10 hover:text-[var(--color-primary)]'}`}
          >
            {cat}
          </a>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {sortedNotes.map((note) => (
          <a href={`/notes/${note.id}`} class="card group">
            {note.data.series && (
              <span class="badge badge-primary mb-2">📖 {note.data.series}</span>
            )}
            <h3 class="font-medium mb-2 group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">{note.data.title}</h3>
            <div class="flex gap-2 flex-wrap">
              <span class="badge">{note.data.category}</span>
              {note.data.tags.slice(0, 2).map((t) => <span class="badge">{t}</span>)}
            </div>
            <time class="text-xs text-[var(--text-muted)] mt-2 block">
              {new Date(note.data.date).toLocaleDateString('zh-CN')}
            </time>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
