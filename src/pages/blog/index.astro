---
import Layout from '../../layouts/Layout.astro';
import MasterDetailLayout from '../../components/MasterDetailLayout.astro';
import { getCollection, render } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="博客" description="技术文章、项目分享、思考总结">
  <section class="section-padding">
    <div class="w-[90%] mx-auto">

      <MasterDetailLayout
        title="📝 个人博客"
        subtitle="技术文章、项目分享、思考总结"
        items={posts.map((p) => ({
          id: p.id,
          title: p.data.title,
          category: p.data.category,
          tags: p.data.tags,
          date: p.data.date,
          summary: p.data.summary,
          coverImage: p.data.coverImage,
        }))}
      >
        <!-- Pre-rendered article content (hidden until selected) -->
        {await Promise.all(posts.map(async (post) => {
          const { Content } = await render(post);
          return (
            <div class="md-article prose max-w-none" data-article-id={post.id}>
              {/* Article meta */}
              <div class="flex gap-2 mb-4 flex-wrap">
                <span class="badge badge-primary">{post.data.category}</span>
                {post.data.tags.map((tag) => <span class="badge">{tag}</span>)}
              </div>
              <h1 class="text-2xl md:text-3xl font-bold mb-3">{post.data.title}</h1>
              <div class="flex items-center gap-4 text-sm text-[var(--text-muted)] mb-8">
                <time datetime={String(post.data.date)}>
                  {new Date(post.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span>·</span>
                <span>约 {Math.ceil((post.body?.length || 100) / 500)} 分钟阅读</span>
              </div>
              {/* Cover */}
              {post.data.coverImage && (
                <img src={post.data.coverImage} alt={post.data.title} class="w-full rounded-xl mb-8" />
              )}
              {/* Body */}
              <Content />
            </div>
          );
        }))}
      </MasterDetailLayout>

    </div>
  </section>
</Layout>
