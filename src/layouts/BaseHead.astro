---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const { title, description = '个人 AI 综合网站 — 博客 · AI 咨询 · 学习笔记 · AI 工具箱', image, type = 'website' } = Astro.props;
const siteUrl = Astro.url.origin;
const fullTitle = title ? `${title} | BackStocking AI` : 'BackStocking AI';
const ogImage = image || `${siteUrl}/og-default.jpg`;
---

<!doctype html>
<html lang="zh-CN" class="">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  
  {/* Open Graph */}
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:locale" content="zh_CN" />
  
  {/* Twitter Card */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  
  {/* Favicon */}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  {/* Fonts */}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet" />
  
  <slot name="head" />
</head>
<body class="min-h-screen bg-[var(--bg-primary)] text-[var(--text-primary)]">
  <slot />
  <script is:inline>
    // Theme initialization (before paint to avoid flash)
    const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    if (theme === 'dark') document.documentElement.classList.add('dark');
  </script>
</body>
</html>
